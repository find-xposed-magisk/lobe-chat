    "@lobechat/conversation-flow": "workspace:*",
    "@lobechat/types": "workspace:*",
    "@lobechat/utils": "workspace:*",
    "random-words": "^2.0.1",
    "ts-md5": "^2.0.1",
    "type-fest": "^5.7.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.16",
    "dotenv": "^17.4.2",
    "fake-indexeddb": "^6.2.5"
  },
  "peerDependencies": {
    "dayjs": "*",
    "drizzle-orm": "*",
    "drizzle-zod": "*",
